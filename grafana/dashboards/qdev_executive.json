      "targets": [
        {
          "datasource": "mysql",
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  week as time,\n  SUM(CASE WHEN is_new = 1 THEN 1 ELSE 0 END) as 'New Users',\n  SUM(CASE WHEN is_new = 0 THEN 1 ELSE 0 END) as 'Returning Users'\nFROM (\n  SELECT\n    u.user_id,\n    STR_TO_DATE(CONCAT(YEARWEEK(u.timestamp, 1), ' Monday'), '%X%V %W') as week,\n    CASE WHEN STR_TO_DATE(CONCAT(YEARWEEK(u.timestamp, 1), ' Monday'), '%X%V %W') = STR_TO_DATE(CONCAT(YEARWEEK(f.first_seen, 1), ' Monday'), '%X%V %W') THEN 1 ELSE 0 END as is_new\n  FROM lake._tool_q_dev_chat_log u\n  JOIN (SELECT user_id, MIN(timestamp) as first_seen FROM lake._tool_q_dev_chat_log GROUP BY user_id) f ON u.user_id = f.user_id\n  WHERE $__timeFilter(u.timestamp)\n  GROUP BY u.user_id, YEARWEEK(u.timestamp, 1), f.first_seen\n) weekly\nGROUP BY week\nORDER BY week",
          "refId": "A"
        }
      ],
      "title": "New vs Returning Users (Weekly)",
      "type": "timeseries"
    },
