          "rawQuery": true,
          "rawSql": "SELECT\n  STR_TO_DATE(CONCAT(yw, ' Monday'), '%X%V %W') as time,\n  SUM(CASE WHEN yw = first_yw THEN 1 ELSE 0 END) as 'New Users',\n  SUM(CASE WHEN yw != first_yw THEN 1 ELSE 0 END) as 'Returning Users'\nFROM (\n  SELECT DISTINCT u.user_id, YEARWEEK(u.timestamp, 1) as yw, f.first_yw\n  FROM lake._tool_q_dev_chat_log u\n  JOIN (SELECT user_id, YEARWEEK(MIN(timestamp), 1) as first_yw FROM lake._tool_q_dev_chat_log GROUP BY user_id) f\n    ON u.user_id = f.user_id\n  WHERE $__timeFilter(u.timestamp)\n) weekly\nGROUP BY yw\nORDER BY time",
